<?xml version="1.0"?>
<flowgorithm fileversion="4.2">
    <attributes>
        <attribute name="name" value="ejercicio vectores ordenamiento shell sort"/>
        <attribute name="authors" value="Lenovo"/>
        <attribute name="about" value=""/>
        <attribute name="saved" value="2026-05-30 10:09:45 a.&#160;m."/>
        <attribute name="created" value="TGVub3ZvO0RFU0tUT1AtVEdNRjdNQzsyMDI2LTA1LTI5OzEwOjQ5OjE0IHAuwqBtLjszMzE2"/>
        <attribute name="edited" value="TGVub3ZvO0RFU0tUT1AtVEdNRjdNQzsyMDI2LTA1LTI5OzExOjAwOjQzIHAuwqBtLjsxO0xlbm92bztERVNLVE9QLVRHTUY3TUM7MjAyNi0wNS0yODswNzoxOTozMSBwLsKgbS47ZWplcmNpY2lvIHZlY3RvcmVzIG9yZGVuYW1pZW50byBpbnNlcmNjaW9uLmZwcmc7MTE1OTI="/>
        <attribute name="edited" value="TGVub3ZvO0RFU0tUT1AtVEdNRjdNQzsyMDI2LTA1LTMwOzEwOjA5OjQ1IGEuwqBtLjs1OzM0MDU="/>
    </attributes>
    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="v" type="Integer" array="True" size="7"/>
            <declare name="p, i, salto, temporal, pos" type="Integer" array="False" size=""/>
            <call expression="crearvector(v)"/>
            <assign variable="salto" expression="7/2"/>
            <while expression="salto&gt;0">
                <for variable="p" start="salto" end="6" direction="inc" step="1">
                    <assign variable="temporal" expression="v[p]"/>
                    <assign variable="i" expression="p"/>
                    <assign variable="pos" expression="p"/>
                    <while expression="i&gt;=salto">
                        <if expression="v[i - salto] &gt; temporal">
                            <then>
                                <assign variable="v[i]" expression="v[i-salto]"/>
                                <assign variable="pos" expression="i-salto"/>
                                <assign variable="i" expression="i-salto"/>
                            </then>
                            <else>
                                <assign variable="i" expression="-1"/>
                            </else>
                        </if>
                    </while>
                    <assign variable="v[pos]" expression="temporal"/>
                </for>
                <assign variable="salto" expression="salto/2"/>
            </while>
        </body>
    </function>
    <function name="crearvector" type="None" variable="">
        <parameters>
            <parameter name="numeros" type="Integer" array="True"/>
        </parameters>
        <body>
            <declare name="i" type="Integer" array="False" size=""/>
            <for variable="i" start="0" end="6" direction="inc" step="1">
                <input variable="numeros[i]"/>
            </for>
        </body>
    </function>
</flowgorithm>
