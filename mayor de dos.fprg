<flowgorithm fileversion="4.2">
    <attributes>
        <attribute name="name" value="tarea 4"/>
        <attribute name="authors" value="Lenovo"/>
        <attribute name="about" value=""/>
        <attribute name="saved" value="2026-04-21 10:56:06 p.&#160;m."/>
